{
    "name": "woweb/laravel-zgw-client",
    "description": "Laravel package for the Dutch ZGW (Zaakgericht Werken) APIs: Zaken, Catalogi, Documenten and Besluiten.",
    "keywords": ["laravel", "zgw", "openzaak", "zaken", "documenten", "catalogi", "besluiten", "woweb"],
    "license": "EUPL-1.2",
    "type": "library",
    "authors": [
        {
            "name": "Woweb",
            "email": "info@woweb.nl"
        }
    ],
    "require": {
        "php": "^8.2",
        "firebase/php-jwt": "^7.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "deptrac/deptrac": "^3.0",
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "symfony/yaml": "^6.4|^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Woweb\\Zgw\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Woweb\\Zgw\\Tests\\": "tests/",
            "Woweb\\Zgw\\Dev\\": "dev/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Woweb\\Zgw\\ZgwServiceProvider"
            ],
            "aliases": {
                "Zgw": "Woweb\\Zgw\\Facades\\Zgw"
            }
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit",
        "test:coverage": "@php -d pcov.enabled=1 vendor/bin/phpunit --coverage-text",
        "test:coverage-html": "@php -d pcov.enabled=1 vendor/bin/phpunit --coverage-html coverage",
        "contract:fetch": "@php scripts/fetch-specs.php",
        "contract": [
            "@contract:fetch",
            "@php vendor/bin/phpunit --testsuite Contract"
        ],
        "contract:coverage": [
            "@contract:fetch",
            "@php vendor/bin/phpunit tests/Contract/CoverageReportTest.php"
        ],
        "dto:generate": [
            "@php scripts/generate-dtos.php",
            "@php vendor/bin/pint src/Data/Generated src/Data/Writes --quiet"
        ],
        "deptrac": "@php vendor/bin/deptrac analyse --no-progress"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
